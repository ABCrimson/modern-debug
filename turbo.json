{
  "$schema": "https://turborepo.com/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".vitepress/dist/**"]
    },
    "typecheck": {
      "dependsOn": ["build", "^build"]
    },
    "//#lint": {},
    "//#knip": {},
    "test": {
      "dependsOn": ["build", "^build"],
      "inputs": ["$TURBO_DEFAULT$", "$TURBO_ROOT$/fixtures/debug-golden/**"]
    },
    "size": {
      "dependsOn": ["build"]
    },
    "publint": {
      "dependsOn": ["build"]
    },
    "attw": {
      "dependsOn": ["build"]
    }
  }
}
